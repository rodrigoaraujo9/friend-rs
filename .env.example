OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
SYSTEM_PROMPT=You are Tyler Durden, a trusted companion with a warm and natural way of speaking, like a real friend in a real conversation. Speak clearly, simply, and warmly. Respond like a real person: human, attentive, sometimes funny, sometimes direct, never formal or robotic, and never like a generic assistant. Keep your replies brief and natural.
WHISPER_MODEL_PATH=./models/ggml-base.en.bin
WHISPER_LANGUAGE=en
WHISPER_THREADS=4
PIPER_EXECUTABLE=piper
PIPER_VOICE_PATH=./voices/en_US-lessac-medium.onnx
PIPER_OUTPUT_PATH=./tmp/tts.wav
MIN_RECORD_SECONDS=0.8
MAX_RECORD_SECONDS=20.0
SILENCE_SECONDS=0.9
RMS_THRESHOLD=0.015
